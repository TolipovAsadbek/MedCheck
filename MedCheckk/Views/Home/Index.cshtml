@{
    ViewData["Title"] = "Bosh sahifa";
}

<div class="hero">
    <div class="hero-tag">
        <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        O'zbekiston SSV tasdiqlagan ma'lumotlar bazasi
    </div>
    <h1>Retseptingizni<br><em>aqlli tekshiring</em></h1>
    <p>Shifokor yozgan dorilar kasalligingizga to'g'ri kelishini tekshiring, ortiqcha dorilarni aniqlang va arzonroq alternativlar toping.</p>
    <div class="hero-btns">
        <a href="/Check" class="btn btn-white">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            Retseptni tekshirish
        </a>
        <a href="/Doctor" class="btn btn-outline">Shifokorlar bilan bog'lanish →</a>
    </div>
</div>

<div class="stats">
    <div class="stat" style="--accent:#2563eb">
        <div class="stat-icon">💊</div>
        <div class="stat-val">@String.Format("{0:N0}", ViewBag.TotalMedicines)</div>
        <div class="stat-label">Dorilar bazada</div>
    </div>
    <div class="stat" style="--accent:#16a34a">
        <div class="stat-icon">✅</div>
        <div class="stat-val">@String.Format("{0:N0}", ViewBag.TotalChecks)</div>
        <div class="stat-label">Tekshiruv o'tkazildi</div>
    </div>
    <div class="stat" style="--accent:#d97706">
        <div class="stat-icon">💰</div>
        <div class="stat-val">@String.Format("{0:N0}", ViewBag.TotalSavings)</div>
        <div class="stat-label">So'm tejaldi</div>
    </div>
    <div class="stat" style="--accent:#7c3aed">
        <div class="stat-icon">👨‍⚕️</div>
        <div class="stat-val">@ViewBag.TotalDoctors</div>
        <div class="stat-label">Faol shifokor</div>
    </div>
</div>

<div class="g3">
    <div class="card">
        <div style="width:48px;height:48px;background:var(--blue-l);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#2563eb" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
        </div>
        <div class="card-title">Kasallikka mosligi</div>
        <div class="card-sub">Har bir dori kasalligingizga ta'sir qilishini ATC kod va farmakologik guruh orqali tekshiramiz</div>
    </div>
    <div class="card">
        <div style="width:48px;height:48px;background:var(--red-l);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#dc2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="card-title">Xavfli kombinatsiyalar</div>
        <div class="card-sub">Birgalikda qabul qilinganda xavfli bo'ladigan dorilarni avtomatik aniqlaymiz</div>
    </div>
    <div class="card">
        <div style="width:48px;height:48px;background:var(--green-l);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#16a34a" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="card-title">Arzon alternativlar</div>
        <div class="card-sub">Bir xil tarkibli, arzonroq generic dorilarni topib, qancha tejashingizni hisoblaymiz</div>
    </div>
</div>
