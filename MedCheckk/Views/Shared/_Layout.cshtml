<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] — MedCheck</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0a0f1e;
            --ink2: #3d4663;
            --ink3: #8892b0;
            --bg: #f7f8fc;
            --card: #ffffff;
            --border: #e8edf5;
            --blue: #2563eb;
            --blue-l: #dbeafe;
            --green: #16a34a;
            --green-l: #dcfce7;
            --red: #dc2626;
            --red-l: #fee2e2;
            --yellow: #d97706;
            --yellow-l: #fef3c7;
            --purple: #7c3aed;
            --purple-l: #ede9fe;
            --r: 14px;
            --sh: 0 1px 3px rgba(10,15,30,.06),0 8px 24px rgba(10,15,30,.04);
            --sh-lg: 0 4px 6px rgba(10,15,30,.04),0 20px 60px rgba(10,15,30,.1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: 'DM Sans',sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
            line-height: 1.6
        }

        /* NAV */
        .nav {
            background: var(--card);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 200;
            padding: 0 40px;
            height: 64px;
            display: flex;
            align-items: center;
            gap: 0;
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,.92);
        }

        .nav-logo {
            font-family: 'Syne',sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--ink);
            text-decoration: none;
            margin-right: 48px;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: -.5px;
        }

            .nav-logo .dot {
                color: var(--blue)
            }

        .nav-links {
            display: flex;
            gap: 4px;
            flex: 1
        }

            .nav-links a {
                font-size: 14px;
                font-weight: 500;
                color: var(--ink2);
                text-decoration: none;
                padding: 7px 14px;
                border-radius: 8px;
                transition: all .15s;
                letter-spacing: -.1px;
            }

                .nav-links a:hover {
                    background: var(--blue-l);
                    color: var(--blue)
                }

                .nav-links a.active {
                    background: var(--blue-l);
                    color: var(--blue)
                }

        .nav-pill {
            background: var(--green-l);
            color: var(--green);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .5px;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 20px;
        }

        /* MAIN */
        main {
            max-width: 1120px;
            margin: 0 auto;
            padding: 40px 24px
        }

        /* HERO */
        .hero {
            background: linear-gradient(135deg,#0a0f1e 0%,#1e3a8a 60%,#1d4ed8 100%);
            border-radius: 24px;
            padding: 64px 56px;
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(96,165,250,.2) 0%,transparent 70%);
            }

            .hero::after {
                content: '';
                position: absolute;
                bottom: -60px;
                left: 200px;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(167,139,250,.15) 0%,transparent 70%);
            }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.15);
            color: rgba(255,255,255,.8);
            font-size: 12px;
            font-weight: 500;
            padding: 5px 12px;
            border-radius: 20px;
            margin-bottom: 20px;
            backdrop-filter: blur(8px);
        }

        .hero h1 {
            font-family: 'Syne',sans-serif;
            font-size: 52px;
            font-weight: 800;
            color: #fff;
            line-height: 1.08;
            letter-spacing: -2px;
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

            .hero h1 em {
                font-style: normal;
                background: linear-gradient(90deg,#93c5fd,#c4b5fd);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .hero p {
            color: rgba(255,255,255,.65);
            font-size: 17px;
            max-width: 480px;
            line-height: 1.65;
            position: relative;
            z-index: 1;
        }

        .hero-btns {
            display: flex;
            gap: 12px;
            margin-top: 32px;
            position: relative;
            z-index: 1;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 22px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
            font-family: 'DM Sans',sans-serif;
            letter-spacing: -.1px;
        }

        .btn-white {
            background: #fff;
            color: var(--blue)
        }

            .btn-white:hover {
                background: #f0f6ff;
                transform: translateY(-1px);
                box-shadow: 0 8px 24px rgba(0,0,0,.15)
            }

        .btn-outline {
            background: rgba(255,255,255,.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,.2)
        }

            .btn-outline:hover {
                background: rgba(255,255,255,.18)
            }

        .btn-blue {
            background: var(--blue);
            color: #fff
        }

            .btn-blue:hover {
                background: #1d4ed8;
                transform: translateY(-1px);
                box-shadow: 0 8px 20px rgba(37,99,235,.35)
            }

        .btn-ghost {
            background: transparent;
            color: var(--ink2);
            border: 1px solid var(--border)
        }

            .btn-ghost:hover {
                background: var(--bg);
                border-color: var(--ink3)
            }

        .btn-sm {
            padding: 7px 14px;
            font-size: 13px;
            border-radius: 8px
        }

        /* STATS */
        .stats {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
            margin-bottom: 40px
        }

        .stat {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 24px;
            box-shadow: var(--sh);
            position: relative;
            overflow: hidden;
        }

            .stat::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--accent,var(--blue));
                border-radius: var(--r) var(--r) 0 0;
            }

        .stat-icon {
            font-size: 28px;
            margin-bottom: 12px
        }

        .stat-val {
            font-family: 'Syne',sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: var(--ink);
            letter-spacing: -1px
        }

        .stat-label {
            font-size: 13px;
            color: var(--ink3);
            margin-top: 2px;
            font-weight: 400
        }

        /* CARD */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 28px;
            box-shadow: var(--sh)
        }

        .card-title {
            font-family: 'Syne',sans-serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--ink);
            letter-spacing: -.3px;
            margin-bottom: 4px
        }

        .card-sub {
            font-size: 13px;
            color: var(--ink3);
            margin-bottom: 20px
        }

        /* SEARCH */
        .search-wrap {
            position: relative
        }

            .search-wrap svg.ico {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--ink3);
                pointer-events: none
            }

            .search-wrap input {
                width: 100%;
                padding: 12px 16px 12px 42px;
                border: 1.5px solid var(--border);
                border-radius: 10px;
                font-size: 14px;
                font-family: 'DM Sans',sans-serif;
                background: var(--bg);
                color: var(--ink);
                outline: none;
                transition: all .15s;
            }

                .search-wrap input:focus {
                    border-color: var(--blue);
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(37,99,235,.1)
                }

                .search-wrap input::placeholder {
                    color: var(--ink3)
                }

        /* DROPDOWN */
        .dropdown {
            position: absolute;
            z-index: 300;
            top: calc(100% + 6px);
            left: 0;
            right: 0;
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            box-shadow: var(--sh-lg);
            max-height: 320px;
            overflow-y: auto;
        }

        .dd-item {
            padding: 12px 16px;
            cursor: pointer;
            border-bottom: 1px solid var(--border);
            transition: background .1s
        }

            .dd-item:last-child {
                border-bottom: none
            }

            .dd-item:hover {
                background: var(--blue-l)
            }

            .dd-item:first-child {
                border-radius: 10px 10px 0 0
            }

            .dd-item:last-child {
                border-radius: 0 0 10px 10px
            }

        .dd-name {
            font-size: 14px;
            font-weight: 500;
            color: var(--ink)
        }

        .dd-meta {
            font-size: 12px;
            color: var(--ink3);
            margin-top: 2px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap
        }

        /* CHIPS */
        .chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            min-height: 44px;
            padding: 8px;
            background: var(--bg);
            border-radius: 10px;
            border: 1.5px solid var(--border)
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--blue-l);
            color: var(--blue);
            border-radius: 20px;
            padding: 5px 10px 5px 12px;
            font-size: 13px;
            font-weight: 500;
            animation: pop .2s ease;
        }
        @@keyframes pop {
            from

        {
            transform: scale(.8);
            opacity: 0
        }

        to {
            transform: scale(1);
            opacity: 1
        }

        }

        .chip-x {
            border: none;
            background: none;
            cursor: pointer;
            color: var(--blue);
            font-size: 17px;
            line-height: 1;
            padding: 0;
            opacity: .7
        }

            .chip-x:hover {
                opacity: 1
            }

        .chips-hint {
            font-size: 13px;
            color: var(--ink3);
            align-self: center
        }

        /* BADGE */
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .3px;
            text-transform: uppercase
        }

        .badge-rx {
            background: #fef2f2;
            color: #dc2626
        }

        .badge-free {
            background: #f0fdf4;
            color: #16a34a
        }

        .badge-generic {
            background: var(--green-l);
            color: var(--green)
        }

        .badge-brand {
            background: var(--purple-l);
            color: var(--purple)
        }

        .badge-critical {
            background: #7f1d1d;
            color: #fff
        }

        .badge-high {
            background: var(--red-l);
            color: var(--red)
        }

        .badge-medium {
            background: var(--yellow-l);
            color: var(--yellow)
        }

        .badge-low {
            background: var(--blue-l);
            color: var(--blue)
        }

        /* ALERT */
        .alert {
            padding: 14px 18px;
            border-radius: 10px;
            font-size: 14px;
            margin-bottom: 12px;
            display: flex;
            gap: 10px;
            align-items: flex-start;
            line-height: 1.55
        }

        .alert-red {
            background: var(--red-l);
            border: 1px solid #fecaca;
            color: #991b1b
        }

        .alert-yellow {
            background: var(--yellow-l);
            border: 1px solid #fde68a;
            color: #92400e
        }

        .alert-green {
            background: var(--green-l);
            border: 1px solid #bbf7d0;
            color: #14532d
        }

        .alert-blue {
            background: var(--blue-l);
            border: 1px solid #bfdbfe;
            color: #1e40af
        }

        /* TABLE */
        table {
            width: 100%;
            border-collapse: collapse
        }

        th {
            font-size: 11px;
            font-weight: 700;
            color: var(--ink3);
            text-transform: uppercase;
            letter-spacing: .6px;
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
            text-align: left;
            background: #fafbfd
        }

        td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
            color: var(--ink);
            vertical-align: middle
        }

        tr:last-child td {
            border-bottom: none
        }

        tr:hover td {
            background: #fafbfd
        }

        /* FORM */
        .form-group {
            margin-bottom: 18px
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--ink2);
            margin-bottom: 6px;
            letter-spacing: -.1px
        }

        input[type=text], input[type=tel], textarea, select {
            width: 100%;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 14px;
            font-family: 'DM Sans',sans-serif;
            outline: none;
            background: var(--bg);
            color: var(--ink);
            transition: all .15s;
        }

            input[type=text]:focus, input[type=tel]:focus, textarea:focus, select:focus {
                border-color: var(--blue);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(37,99,235,.1);
            }

        textarea {
            resize: vertical;
            min-height: 100px
        }

        /* GRID */
        .g2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px
        }

        .g3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px
        }

        /* RESULT PRICE BOX */
        .price-box {
            background: linear-gradient(135deg,#0a0f1e,#1e3a8a);
            border-radius: 16px;
            padding: 28px 32px;
            color: #fff;
        }

        .price-box-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,.1)
        }

            .price-box-row:last-child {
                border-bottom: none;
                padding-top: 16px
            }

        .price-label {
            font-size: 14px;
            color: rgba(255,255,255,.6)
        }

        .price-val {
            font-family: 'Syne',sans-serif;
            font-size: 20px;
            font-weight: 700
        }

        .price-savings {
            color: #4ade80;
            font-size: 26px
        }

        /* DOCTOR CARD */
        .doc-card {
            background: var(--card);
            border: 1.5px solid var(--border);
            border-radius: var(--r);
            padding: 24px;
            box-shadow: var(--sh);
            transition: all .2s;
            cursor: pointer;
        }

            .doc-card:hover {
                border-color: var(--blue);
                box-shadow: 0 8px 32px rgba(37,99,235,.12);
                transform: translateY(-2px)
            }

        .doc-avatar {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: linear-gradient(135deg,var(--blue),var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne',sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 16px;
            flex-shrink: 0;
        }

        .doc-name {
            font-family: 'Syne',sans-serif;
            font-size: 16px;
            font-weight: 700;
            letter---spacing: -.3px
        }

        .doc-spec {
            font-size: 13px;
            color: var(--blue);
            font-weight: 500;
            margin-top: 2px
        }

        .doc-hospital {
            font-size: 12px;
            color: var(--ink3);
            margin-top: 4px
        }

        .doc-fee {
            font-family: 'Syne',sans-serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--ink);
            margin-top: 12px
        }

            .doc-fee span {
                font-size: 12px;
                font-weight: 400;
                color: var(--ink3)
            }

        .doc-status {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--green);
            display: inline-block;
            margin-right: 4px
        }

            .doc-status.off {
                background: #d1d5db
            }

        /* MODAL */
        .modal-bg {
            position: fixed;
            inset: 0;
            background: rgba(10,15,30,.6);
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
            animation: fadein .15s
        }
        @@keyframes fadein {
            from

        {
            opacity: 0
        }

        to {
            opacity: 1
        }

        }

        .modal {
            background: #fff;
            border-radius: 20px;
            padding: 36px;
            width: 100%;
            max-width: 480px;
            box-shadow: var(--sh-lg);
            animation: slidein .2s
        }
        @@keyframes slidein {
            from

        {
            transform: translateY(20px);
            opacity: 0
        }

        to {
            transform: translateY(0);
            opacity: 1
        }

        }

        .modal-title {
            font-family: 'Syne',sans-serif;
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 4px
        }

        .modal-sub {
            font-size: 14px;
            color: var(--ink3);
            margin-bottom: 24px
        }

        /* EMPTY */
        .empty {
            text-align: center;
            padding: 56px 24px;
            color: var(--ink3)
        }

            .empty svg {
                width: 52px;
                height: 52px;
                margin: 0 auto 14px;
                opacity: .3;
                display: block
            }

            .empty p {
                font-size: 14px
            }

        /* DIVIDER */
        .divider {
            height: 1px;
            background: var(--border);
            margin: 24px 0
        }

        /* SAVINGS HIGHLIGHT */
        .savings-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--green-l);
            color: var(--green);
            font-size: 13px;
            font-weight: 600;
            padding: 5px 12px;
            border-radius: 20px;
        }

        @@media(max - width:768px) {
            .stats

        {
            grid-template-columns: 1fr 1fr
        }

        .g2, .g3 {
            grid-template-columns: 1fr
        }

        .hero {
            padding: 40px 28px
        }

            .hero h1 {
                font-size: 36px
            }

        .nav {
            padding: 0 16px
        }

        main {
            padding: 24px 16px
        }

        }</style>
</head>
<body>
    <nav class="nav">
        <a class="nav-logo" href="/">Med<span class="dot">.</span>Check</a>
        <div class="nav-links">
            <a href="/" class="@(Ctx("Home", "Index"))">Bosh sahifa</a>
            <a href="/Check" class="@(Ctx("Check", "Index"))">Retsept tekshiruvi</a>
            <a href="/Doctor" class="@(Ctx("Doctor", "Index"))">Shifokorlar</a>
        </div>
        <span class="nav-pill">SSV 2025</span>
    </nav>

    <main>
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-red" style="margin-bottom:20px">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                @TempData["Error"]
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-green" style="margin-bottom:20px">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                @TempData["Success"]
            </div>
        }
        @RenderBody()
    </main>

    @functions {
        string Ctx(string c, string a)
        {
            var rc = ViewContext.RouteData.Values["controller"]?.ToString();
            var ra = ViewContext.RouteData.Values["action"]?.ToString();
            return (rc == c && (a == "*" || ra == a)) ? "active" : "";
        }
    }
</body>
</html>
