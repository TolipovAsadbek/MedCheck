@using MedCheck.Models
@model List<Doctor>
@{
    ViewData["Title"] = "Shifokorlar";
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px">
    <div>
        <h1 style="font-family:'Syne',sans-serif;font-size:28px;font-weight:800;letter-spacing:-.5px">Shifokorlar</h1>
        <p style="font-size:15px;color:var(--ink3);margin-top:6px">Mutaxassis shifokorlar bilan bog'laning</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="empty">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <p>Shifokorlar bazaga qo'shilmagan.<br>Avval <code>seed.sql</code> ni ishga tushiring.</p>
        </div>
    </div>
}
else
{
    <div class="g3">
        @foreach (var doc in Model)
        {
            <div class="doc-card" onclick="openModal(@doc.Id,'@doc.FullName','@doc.Specialization')">
                <div style="display:flex;gap:14px;align-items:flex-start">
                    <div class="doc-avatar">@doc.FullName.Split(' ').Take(2).Select(w => w[0]).Aggregate("", (a, c) => a + c)</div>
                    <div style="flex:1;min-width:0">
                        <div class="doc-name">@doc.FullName</div>
                        <div class="doc-spec">@doc.Specialization</div>
                        <div class="doc-hospital">@doc.Hospital</div>
                    </div>
                </div>
                <div style="margin-top:14px;font-size:13px;color:var(--ink2);line-height:1.55">@(doc.Bio?.Length > 90 ? doc.Bio[..90] + "…" : doc.Bio)</div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;padding-top:14px;border-top:1px solid var(--border)">
                    <div>
                        <div class="doc-fee">@String.Format("{0:N0}", doc.ConsultationFee) <span>so'm</span></div>
                        <div style="font-size:11px;color:var(--ink3)">konsultatsiya</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:5px;font-size:12px;font-weight:500">
                        <span class="doc-status @(doc.IsAvailable ? "" : "off")"></span>
                        <span style="color:@(doc.IsAvailable ? "var(--green)" : "var(--ink3)")">@(doc.IsAvailable ? "Faol" : "Band")</span>
                    </div>
                </div>
                @if (doc.IsAvailable)
                {
                    <div style="margin-top:10px">
                        <button type="button" class="btn btn-blue" style="width:100%;justify-content:center"
                                onclick="event.stopPropagation();openModal(@doc.Id,'@doc.FullName','@doc.Specialization')">
                            Murojaat yuborish
                        </button>
                    </div>
                }
            </div>
        }
    </div>
}

<!-- MODAL -->
<div class="modal-bg" id="modalBg" style="display:none" onclick="if(event.target===this)closeModal()">
    <div class="modal">
        <div class="modal-title" id="modalTitle">Shifokorga murojaat</div>
        <div class="modal-sub" id="modalSub">Xabaringizni qoldiring — shifokor bog'lanadi</div>

        <form method="post" action="/Doctor/Contact">
            <input type="hidden" name="doctorId" id="modalDoctorId" />

            <div class="form-group">
                <label>Ismingiz *</label>
                <input type="text" name="patientName" placeholder="Ism Familiya" required />
            </div>
            <div class="form-group">
                <label>Telefon</label>
                <input type="tel" name="patientPhone" placeholder="+998 90 000 00 00" />
            </div>
            <div class="form-group" style="margin-bottom:20px">
                <label>Xabar *</label>
                <textarea name="message" placeholder="Kasallik, simptomlar va savolingizni yozing..." required></textarea>
            </div>

            <div style="display:flex;gap:10px">
                <button type="button" class="btn btn-ghost" style="flex:1;justify-content:center" onclick="closeModal()">Bekor qilish</button>
                <button type="submit" class="btn btn-blue" style="flex:2;justify-content:center">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                    Yuborish
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id, name, spec) {
      document.getElementById('modalDoctorId').value = id;
      document.getElementById('modalTitle').textContent = 'Dr. ' + name.replace('Dr. ','');
      document.getElementById('modalSub').textContent = spec + ' mutaxassisiga murojaat';
      document.getElementById('modalBg').style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      document.getElementById('modalBg').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });
</script>
