@using MedCheck.Models
@model List<Check>
@{ ViewData["Title"] = "Tekshiruv tarixi"; }

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px">
  <div>
    <h1 style="font-family:'Syne',sans-serif;font-size:28px;font-weight:800;letter-spacing:-.5px">Tekshiruv tarixi</h1>
    <p style="font-size:15px;color:var(--ink3);margin-top:6px">So'nggi @Model.Count ta tekshiruv</p>
  </div>
  <a href="/Check" class="btn btn-blue">+ Yangi tekshiruv</a>
</div>

@if (!Model.Any())
{
  <div class="card">
    <div class="empty">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p>Hali tekshiruv o'tkazilmagan</p>
      <a href="/Check" class="btn btn-blue" style="margin-top:16px;display:inline-flex">Birinchi tekshiruvni boshlash</a>
    </div>
  </div>
}
else
{
  <div class="card" style="padding:0;overflow:hidden">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Kasallik</th>
          <th>Dorilar</th>
          <th>Asl narx</th>
          <th>Optimallashtirilgan</th>
          <th>Tejash</th>
          <th>Sana</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var c in Model)
        {
          var hasSavings = c.Savings > 0;
          <tr style="cursor:pointer" onclick="location.href='/Check/Detail/@c.Id'">
            <td style="color:var(--ink3);font-size:13px;font-weight:500">#@c.Id</td>
            <td>
              <div style="font-weight:500">@(c.Disease?.NameUz ?? "—")</div>
              @if (!string.IsNullOrEmpty(c.PatientNote))
              {
                <div style="font-size:12px;color:var(--ink3)">@(c.PatientNote.Length > 40 ? c.PatientNote[..40]+"…" : c.PatientNote)</div>
              }
            </td>
            <td>
              <span style="background:var(--blue-l);color:var(--blue);font-size:12px;font-weight:600;padding:2px 8px;border-radius:20px">
                @c.Items.Count ta dori
              </span>
            </td>
            <td style="font-weight:500">@String.Format("{0:N0}", c.TotalOriginalPrice) <span style="color:var(--ink3);font-size:12px">so'm</span></td>
            <td style="font-weight:500;color:var(--blue)">@String.Format("{0:N0}", c.TotalOptimizedPrice) <span style="color:var(--ink3);font-size:12px">so'm</span></td>
            <td>
              @if (hasSavings)
              {
                <span class="savings-tag">
                  <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  @String.Format("{0:N0}", c.Savings) so'm
                </span>
              }
              else
              {
                <span style="color:var(--ink3);font-size:13px">—</span>
              }
            </td>
            <td style="font-size:13px;color:var(--ink3);white-space:nowrap">@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>
              <a href="/Check/Detail/@c.Id" class="btn btn-ghost btn-sm" onclick="event.stopPropagation()">Ko'rish</a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  <!-- Jami tejash -->
  <div>
  @{
    var totalSavings = Model.Sum(c => c.Savings);
    var totalOriginal = Model.Sum(c => c.TotalOriginalPrice);
  }
  </div>
  @if (totalSavings > 0)
  {
    <div style="margin-top:16px;padding:20px 24px;background:linear-gradient(135deg,#052e16,#14532d);border-radius:14px;display:flex;justify-content:space-between;align-items:center">
      <div>
        <div style="font-size:13px;color:rgba(255,255,255,.6);margin-bottom:4px">Jami @Model.Count ta tekshiruvda tejash</div>
        <div style="font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:#4ade80">
          @String.Format("{0:N0}", totalSavings) so'm
        </div>
      </div>
      <div style="text-align:right">
        <div style="font-size:13px;color:rgba(255,255,255,.6);margin-bottom:4px">Asl narxdan tejash</div>
        <div style="font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:#86efac">
          @(totalOriginal > 0 ? ((int)Math.Round(totalSavings / totalOriginal * 100)) : 0)%
        </div>
      </div>
    </div>
  }
}
