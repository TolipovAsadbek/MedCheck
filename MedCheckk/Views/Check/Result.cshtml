@using MedCheck.ViewModels
@model CheckResultViewModel
@{
    ViewData["Title"] = "Tahlil natijasi";
}

<div style="max-width:800px;margin:0 auto">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px">
        <div>
            <h1 style="font-family:'Syne',sans-serif;font-size:26px;font-weight:800;letter-spacing:-.5px">Tahlil natijasi</h1>
            <p style="font-size:14px;color:var(--ink3);margin-top:4px">Kasallik: <strong style="color:var(--ink)">@Model.DiseaseName</strong></p>
        </div>
        <a href="/Check" class="btn btn-ghost btn-sm">+ Yangi tekshiruv</a>
    </div>

    @{
        var irrelevant = Model.Items.Where(i => !i.IsRelevant).ToList();
        var duplicates = Model.Items.Where(i => i.IsDuplicate).ToList();
        var interactions = Model.Interactions;
        var correct = Model.Items.Where(i => i.IsRelevant && !i.IsDuplicate).ToList();
        bool hasIssues = irrelevant.Any() || duplicates.Any() || interactions.Any();
    }

    @if (!hasIssues)
    {
        <div class="alert alert-green" style="margin-bottom:20px;font-size:15px;font-weight:500">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Barcha dorilar <strong>@Model.DiseaseName</strong> uchun mos! Muammo aniqlanmadi.
        </div>
    }

    @if (interactions.Any())
    {
        <div class="card" style="margin-bottom:16px;border-left:4px solid var(--red)">
            <div class="card-title" style="color:var(--red)">⚠️ Xavfli kombinatsiyalar (@interactions.Count ta)</div>
            <div class="card-sub">Bu dorilarni birgalikda qabul qilish xavfli!</div>
            @foreach (var w in interactions)
            {
                <div class="alert @(w.Severity == "Critical" ? "alert-red" : w.Severity == "High" ? "alert-red" : "alert-yellow")" style="margin-bottom:8px">
                    <div>
                        <div style="font-weight:700;margin-bottom:3px">
                            @w.MedA <span style="opacity:.5">+</span> @w.MedB
                            <span class="badge badge-@w.Severity.ToLower()" style="margin-left:8px">@w.Severity</span>
                        </div>
                        <div style="font-size:13px">@w.Description</div>
                    </div>
                </div>
            }
        </div>
    }

    @if (irrelevant.Any())
    {
        <div class="card" style="margin-bottom:16px;border-left:4px solid var(--red)">
            <div class="card-title" style="color:var(--red)">❌ Kasallikka mos kelmaydigan dorilar (@irrelevant.Count ta)</div>
            <div class="card-sub">Bu dorilar "@Model.DiseaseName" kasalligini davolashga yordam bermaydi</div>
            @foreach (var it in irrelevant)
            {
                <div style="padding:12px 16px;background:var(--red-l);border-radius:10px;margin-bottom:8px">
                    <div style="font-weight:600;color:var(--red)">@it.Name</div>
                    <div style="font-size:13px;color:#991b1b;margin-top:2px">@it.IssueReason</div>
                    @if (it.Alternative != null)
                    {
                        <div style="margin-top:6px;font-size:12px;color:var(--ink2)">
                            💡 Alternativ yo'q, lekin bu dorini olib tashlash mumkin
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (duplicates.Any())
    {
        <div class="card" style="margin-bottom:16px;border-left:4px solid var(--yellow)">
            <div class="card-title" style="color:var(--yellow)">⚡ Takroriy ta'sirli dorilar (@duplicates.Count ta)</div>
            <div class="card-sub">Bir xil tarkibli dorilar — biri ortiqcha!</div>
            @foreach (var it in duplicates)
            {
                <div style="padding:12px 16px;background:var(--yellow-l);border-radius:10px;margin-bottom:8px">
                    <div style="font-weight:600;color:var(--yellow)">@it.Name</div>
                    <div style="font-size:13px;color:#92400e;margin-top:2px">@it.IssueReason</div>
                </div>
            }
        </div>
    }

    @if (correct.Any())
    {
        <div class="card" style="margin-bottom:16px">
            <div class="card-title">✅ Mos dorilar va alternativlar</div>
            <div class="card-sub">To'g'ri dorilar — arzonroq generic variantlar ham ko'rsatilgan</div>
            <table>
                <thead>
                    <tr>
                        <th>Dori nomi</th>
                        <th>Kategoriya</th>
                        <th>Narx</th>
                        <th>Alternativ</th>
                        <th>Tejash</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var it in correct)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:500">@it.Name</div>
                                <div style="font-size:12px;color:var(--ink3)">@it.GenericName</div>
                            </td>
                            <td><span style="font-size:13px;color:var(--ink2)">@it.Category</span></td>
                            <td><strong style="font-size:15px">@String.Format("{0:N0}", it.Price)</strong> <span style="font-size:12px;color:var(--ink3)">so'm</span></td>
                            <td>
                                @if (it.Alternative != null)
                                {
                                    <div style="font-size:13px;font-weight:500;color:var(--green)">@it.Alternative.Name</div>
                                    <div style="font-size:12px;color:var(--ink3)">@String.Format("{0:N0}", it.Alternative.Price) so'm</div>
                                }
                                else
                                {
                                    <span style="font-size:13px;color:var(--ink3)">—</span>
                                }
                            </td>
                            <td>
                                @if (it.Alternative != null && it.Alternative.SavingPercent > 0)
                                {
                                    <span class="savings-tag">−@it.Alternative.SavingPercent%</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- NARX BLOKI -->
    <div class="price-box" style="margin-bottom:24px">
        <div style="font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:rgba(255,255,255,.5);letter-spacing:1px;text-transform:uppercase;margin-bottom:16px">Narx tahlili</div>
        <div class="price-box-row">
            <div class="price-label">Hozirgi narx</div>
            <div class="price-val">@String.Format("{0:N0}", Model.TotalOriginal) <span style="font-size:14px;opacity:.5">so'm</span></div>
        </div>
        <div class="price-box-row">
            <div class="price-label">Alternativlar bilan</div>
            <div class="price-val" style="color:#93c5fd">@String.Format("{0:N0}", Model.TotalOptimized) <span style="font-size:14px;opacity:.5">so'm</span></div>
        </div>
        <div class="price-box-row">
            <div class="price-label" style="color:#4ade80;font-weight:600">💰 Tejash mumkin</div>
            <div class="price-val price-savings">@String.Format("{0:N0}", Model.Savings) <span style="font-size:14px">so'm</span></div>
        </div>
    </div>

    <div style="display:flex;gap:12px;justify-content:flex-end">
        <a href="/Doctor" class="btn btn-ghost">Shifokorga murojaat →</a>
        <a href="/Check" class="btn btn-blue">Yangi tekshiruv</a>
    </div>
</div>
